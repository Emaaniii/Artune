# --- Supabase ---
# Get these from your Supabase project dashboard:
#   Project Settings → API → "Project URL"           → NEXT_PUBLIC_SUPABASE_URL
#   Project Settings → API → "Project API Keys" tab  → "anon" key → NEXT_PUBLIC_SUPABASE_ANON_KEY
#                                                  → "service_role" key → SUPABASE_SERVICE_ROLE_KEY
# The service role key bypasses Row Level Security — never ship it to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# K-Net mock signing secret. Replace with real merchant credentials in prod.
KNET_HMAC_SECRET="change-me-knet-hmac-secret"
APP_URL="http://localhost:3000"

# --- Messaging adapter ---
# SMS_PROVIDER=mock     -> codes logged to server console (dev)
# SMS_PROVIDER=twilio   -> real SMS via Twilio; requires TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_FROM
# SMS_PROVIDER=whatsapp -> WhatsApp via Twilio sandbox; requires TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_WHATSAPP_FROM
SMS_PROVIDER="mock"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
TWILIO_WHATSAPP_FROM="+14155238886"

# --- Dev-only OTP fail-safe (leave blank in production) ---
# When AUTH_DEV_BYPASS_KEY is set (>= 16 chars), the /api/auth/dev-login route
# accepts { phone, devKey } and mints a session for an existing profile without
# OTP. NEXT_PUBLIC_AUTH_DEV_BYPASS=1 reveals the UI link on the auth screen.
# Useful when the Twilio WhatsApp Sandbox kicks the recipient out and OTP can't
# be delivered. Both must be unset in production.
AUTH_DEV_BYPASS_KEY=""
NEXT_PUBLIC_AUTH_DEV_BYPASS=""

# --- Payment adapter (MyFatoorah) ---
# Get your test key from https://docs.myfatoorah.com/docs/api-key
# The Next.js callback route uses these to verify payment status. The Supabase
# edge function `myfatoorah-initiate` reads the same names from its own env.
# If unset, the public Kuwait sandbox key from the docs is used.
MYFATOORAH_API_KEY=""
MYFATOORAH_BASE_URL="https://apitest.myfatoorah.com"
