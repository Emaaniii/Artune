# --- Database (Postgres) ---
# DATABASE_URL = pooled connection (used by the app at runtime).
# DIRECT_URL   = unpooled connection (used by `prisma migrate`).
#
# Vercel Postgres: set DATABASE_URL = POSTGRES_PRISMA_URL  (or POSTGRES_URL)
#                  set DIRECT_URL   = POSTGRES_URL_NON_POOLING
# Neon:            paste the pooled and unpooled URLs from the Neon dashboard.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# Generate real secrets in prod:  openssl rand -hex 32
SESSION_SECRET="change-me-min-32-characters-long-random-string"
SESSION_COOKIE_NAME="artune_session"

# K-Net mock signing secret. Replace with real merchant credentials in prod.
KNET_HMAC_SECRET="change-me-knet-hmac-secret"
APP_URL="http://localhost:3000"

# --- Messaging adapter ---
# SMS_PROVIDER=mock     -> codes logged to server console (dev)
# SMS_PROVIDER=twilio   -> real SMS via Twilio; requires TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_FROM
# SMS_PROVIDER=whatsapp -> WhatsApp via Twilio sandbox; requires TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_WHATSAPP_FROM
SMS_PROVIDER="mock"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
TWILIO_WHATSAPP_FROM="+14155238886"

# --- Payment adapter ---
# KNET_PROVIDER=mock    -> in-app fake gateway (dev)
# KNET_PROVIDER=live    -> redirect to real K-Net hosted page; requires KNET_MERCHANT_ID etc.
KNET_PROVIDER="mock"
