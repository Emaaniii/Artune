# Local dev: SQLite. Production: postgresql://user:pass@host/db?sslmode=require (e.g. Neon)
DATABASE_URL="file:./dev.db"

# Generate a real secret in prod:  openssl rand -hex 32
SESSION_SECRET="change-me-min-32-characters-long-random-string"
SESSION_COOKIE_NAME="arting_session"

# K-Net mock signing secret. Replace with real merchant credentials in prod.
KNET_HMAC_SECRET="change-me-knet-hmac-secret"
APP_URL="http://localhost:3000"

# Adapter switches.
# SMS_PROVIDER=mock     -> codes logged to server console (dev)
# SMS_PROVIDER=twilio   -> requires TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_FROM
SMS_PROVIDER="mock"

# KNET_PROVIDER=mock    -> in-app fake gateway (dev)
# KNET_PROVIDER=live    -> redirect to real K-Net hosted page; requires KNET_MERCHANT_ID etc.
KNET_PROVIDER="mock"
