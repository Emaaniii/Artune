# --- Supabase ---
# Get these from your Supabase project dashboard:
#   Project Settings → API → "Project URL"           → NEXT_PUBLIC_SUPABASE_URL
#   Project Settings → API → "Project API Keys" tab  → "anon" key → NEXT_PUBLIC_SUPABASE_ANON_KEY
#                                                  → "service_role" key → SUPABASE_SERVICE_ROLE_KEY
# The service role key bypasses Row Level Security — never ship it to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# K-Net mock signing secret. Replace with real merchant credentials in prod.
KNET_HMAC_SECRET="change-me-knet-hmac-secret"
APP_URL="http://localhost:3000"

# --- Messaging adapter ---
# SMS_PROVIDER=mock     -> codes logged to server console (dev)
# SMS_PROVIDER=twilio   -> real SMS via Twilio; requires TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_FROM
# SMS_PROVIDER=whatsapp -> WhatsApp via Twilio sandbox; requires TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_WHATSAPP_FROM
SMS_PROVIDER="mock"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
TWILIO_WHATSAPP_FROM="+14155238886"

# --- Payment adapter ---
# KNET_PROVIDER=mock    -> in-app fake gateway (dev)
# KNET_PROVIDER=live    -> redirect to real K-Net hosted page; requires KNET_MERCHANT_ID etc.
KNET_PROVIDER="mock"

# --- AI chatbot (OpenRouter) ---
# Sign up at https://openrouter.ai → click your avatar → Keys → Create Key.
# Free models work without payment (default below). To override, set OPENROUTER_MODEL
# to any slug from https://openrouter.ai/models — keep ":free" for zero-cost tiers.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
