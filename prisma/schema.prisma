// Artune database schema.
// Production target: Postgres on Vercel Postgres or Neon.
//   DATABASE_URL = pooled connection (used by the app at runtime).
//   DIRECT_URL   = unpooled connection (used by `prisma migrate`).
// On Vercel Postgres, point DIRECT_URL at POSTGRES_URL_NON_POOLING.
// On Neon, copy the unpooled connection string from the Neon dashboard.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  phone        String    @unique
  name         String?
  username     String?   @unique
  passwordHash String?
  role         String    @default("USER") // USER | ADMIN
  createdAt    DateTime  @default(now())
  bookings     Booking[]
}

model Verification {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model ClassType {
  id        String      @id @default(cuid())
  slug      String      @unique
  name      String
  blurb     String
  imageUrl  String
  priceFils Int
  slots     ClassSlot[]
}

model ClassSlot {
  id          String    @id @default(cuid())
  classTypeId String
  classType   ClassType @relation(fields: [classTypeId], references: [id])
  date        DateTime
  startsAt    String
  endsAt      String
  maxSeats    Int       @default(10)
  bookings    Booking[]

  @@unique([classTypeId, date, startsAt])
}

model Booking {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  slotId     String
  slot       ClassSlot @relation(fields: [slotId], references: [id])
  status     String   @default("PENDING") // PENDING | PAID | CANCELLED
  paymentRef String?
  amountFils Int
  createdAt  DateTime @default(now())
  paidAt     DateTime?

  @@index([userId])
}
